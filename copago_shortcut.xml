<?xml version="1.0" encoding="utf-8"?>
<tryton>
    <data>

        <record model="ir.action.wizard" id="act_open_appointment_copago_services">
            <field name="name">Generar copago</field>
            <field name="wiz_name">wizard.gnuhealth.appointment.copago.services</field>
        </record>
        <record model="ir.action.keyword" id="act_open_appointment_copago_services_keyword">
            <field name="keyword">form_action</field>
            <field name="model">gnuhealth.appointment,-1</field>
            <field name="action" ref="act_open_appointment_copago_services"/>
        </record>

        <record model="ir.action.wizard" id="act_generate_appointment_copago">
            <field name="name">Generar copago v2</field>
            <field name="wiz_name">wizard.gnuhealth.appointment.copago.generate</field>
        </record>
        <record model="ir.action.keyword" id="act_generate_appointment_copago_keyword">
            <field name="keyword">form_action</field>
            <field name="model">gnuhealth.appointment,-1</field>
            <field name="action" ref="act_generate_appointment_copago"/>
        </record>

        <record model="ir.action.wizard" id="act_generate_appointment_copago_print">
            <field name="name">Generar copago v3</field>
            <field name="wiz_name">wizard.gnuhealth.appointment.copago.print</field>
        </record>
        <record model="ir.action.keyword" id="act_generate_appointment_copago_print_keyword">
            <field name="keyword">form_action</field>
            <field name="model">gnuhealth.appointment,-1</field>
            <field name="action" ref="act_generate_appointment_copago_print"/>
        </record>

        <record model="ir.action.act_window" id="act_copago_patient_services">
            <field name="name">Services</field>
            <field name="res_model">gnuhealth.health_service</field>
        </record>
        <record model="ir.action.act_window.view" id="act_copago_patient_services_tree">
            <field name="sequence" eval="10"/>
            <field name="view" ref="health_services.gnuhealth_health_service_tree"/>
            <field name="act_window" ref="act_copago_patient_services"/>
        </record>
        <record model="ir.action.act_window.view" id="act_copago_patient_services_form">
            <field name="sequence" eval="20"/>
            <field name="view" ref="health_services.gnuhealth_health_service_view"/>
            <field name="act_window" ref="act_copago_patient_services"/>
        </record>

        <record model="ir.action.act_window" id="act_copago_invoice">
            <field name="name">Invoice</field>
            <field name="res_model">account.invoice</field>
        </record>
        <record model="ir.action.act_window.view" id="act_copago_invoice_form">
            <field name="sequence" eval="10"/>
            <field name="view" ref="health_services.invoice_view_form"/>
            <field name="act_window" ref="act_copago_invoice"/>
        </record>
        <record model="ir.action.act_window.view" id="act_copago_invoice_tree">
            <field name="sequence" eval="20"/>
            <field name="view" ref="health_services.invoice_view_tree"/>
            <field name="act_window" ref="act_copago_invoice"/>
        </record>

        <record model="ir.action.report" id="account_invoice.report_invoice">
            <field name="report">account_invoice/invoice.fodt</field>
        </record>

        <record model="ir.action.report" id="report_copago_invoice">
            <field name="name">Copago Invoice</field>
            <field name="model">account.invoice</field>
            <field name="report_name">health_copago_shortcut.invoice</field>
            <field name="report">health_copago_shortcut/report/invoice.fodt</field>
            <field name="single" eval="True"/>
        </record>

    </data>
</tryton>
